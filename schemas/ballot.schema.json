{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lerna-Labs/ekklesia-hydra/schemas/ballot.schema.json",
  "title": "BallotDefinition",
  "description": "Full ballot definition pinned to IPFS by POST /prepare. Combines CIP-179 surveyDetails core fields with the Ekklesia extension block. The blake2b_256 of the canonical JSON of this object is committed to the on-chain (600) ballot definition datum as `contentHash`.",
  "type": "object",
  "required": ["specVersion", "title", "description", "questions", "roleWeighting", "endEpoch", "ekklesia"],
  "additionalProperties": false,
  "properties": {
    "specVersion": {
      "type": "string",
      "description": "Ekklesia spec version. Currently '0.3.0'.",
      "examples": ["0.3.0"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short title — also embedded in the on-chain (600) datum."
    },
    "description": { "type": "string" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "description": "Order matters — leaf order in the content merkle tree. Reordering changes contentHash.",
      "items": { "$ref": "#/$defs/BallotQuestion" }
    },
    "roleWeighting": { "$ref": "#/$defs/RoleWeighting" },
    "endEpoch": {
      "type": "integer",
      "minimum": 0,
      "description": "Cardano epoch at which voting ends."
    },
    "ekklesia": { "$ref": "#/$defs/EkklesiaBallotExtension" }
  },
  "$defs": {
    "BallotOption": {
      "type": "object",
      "required": ["label", "value"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": {
          "type": "integer",
          "description": "Stable integer identifier — must be unique within a question. Appears in signed vote payloads and IPFS evidence; changing it after mint breaks verification."
        }
      }
    },
    "BallotQuestion": {
      "type": "object",
      "required": ["questionId", "question", "method"],
      "additionalProperties": false,
      "properties": {
        "questionId": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "method": {
          "type": "string",
          "enum": ["binary", "single-choice", "multi-choice", "range", "ranked", "weighted"]
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/BallotOption" }
        },
        "minSelections": { "type": "integer", "minimum": 0 },
        "maxSelections": { "type": "integer", "minimum": 1 },
        "valueRange": {
          "type": "object",
          "required": ["min", "max"],
          "additionalProperties": false,
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" }
          }
        },
        "rankCount": { "type": "integer", "minimum": 1 },
        "budget": {
          "type": "integer",
          "minimum": 1,
          "description": "Total points the voter must allocate across options. Weights submitted must sum exactly to this value."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "method": { "const": "range" } }, "required": ["method"] },
          "then": { "required": ["valueRange"] }
        },
        {
          "if": { "properties": { "method": { "const": "weighted" } }, "required": ["method"] },
          "then": { "required": ["options", "budget"] }
        },
        {
          "if": { "properties": { "method": { "enum": ["binary", "single-choice", "multi-choice", "ranked"] } }, "required": ["method"] },
          "then": { "required": ["options"] }
        }
      ]
    },
    "RoleWeighting": {
      "type": "object",
      "additionalProperties": false,
      "description": "Maps each role to how its votes are aggregated at tally time. Only roles you intend to count need to be listed.",
      "properties": {
        "DRep": { "enum": ["CredentialBased", "StakeBased"] },
        "SPO": { "enum": ["CredentialBased", "StakeBased", "PledgeBased"] },
        "CC": { "enum": ["CredentialBased"] },
        "Stakeholder": { "enum": ["StakeBased"] }
      }
    },
    "EkklesiaBallotExtension": {
      "type": "object",
      "required": ["namespace", "votingAuthority", "context", "acceptedCredentials", "merkleRoot", "ballotIpfsCid", "votingWindow"],
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1,
          "description": "Source for the 28-byte fingerprint (blake2b_224(namespace)). Filled by the middleware from the /prepare request body."
        },
        "votingAuthority": {
          "type": "string",
          "description": "Bech32 address of the intended voting authority. Advisory metadata only — the on-chain (600) datum always records the middleware's admin address."
        },
        "context": { "const": "hydra-head" },
        "acceptedCredentials": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["drep", "pool", "calidus", "stake", "stake_test", "addr", "addr_test"]
          },
          "minItems": 1
        },
        "merkleRoot": {
          "type": "string",
          "pattern": "^[0-9a-f]{0,64}$",
          "description": "blake2b_256 merkle root of the question leaves, hex. Computed and filled by the middleware (empty in the request body)."
        },
        "ballotIpfsCid": {
          "type": "string",
          "description": "IPFS CID of this ballot JSON. Filled by the middleware ('self' inside the pinned copy to avoid a self-reference loop)."
        },
        "votingWindow": {
          "type": "object",
          "required": ["open", "close"],
          "additionalProperties": false,
          "properties": {
            "open": {
              "type": "string",
              "format": "date-time",
              "description": "ISO-8601 UTC. Doubles as the timelock anchor for the minting policy — must be in the future at /prepare time."
            },
            "close": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    }
  }
}
