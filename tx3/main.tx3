party Voting_Authority;

env {
    minting_script: Bytes,
    token_policy: Bytes,
}

// ---------------------------------------------------------------------------
// Voter token datum — slim; full evidence lives on IPFS
// ---------------------------------------------------------------------------

type Vote {
    VoterId: Bytes,
    Version: Int,
    MerkleRoot: Bytes,
    VoteHash: Bytes,
    IpfsCid: Bytes,
}

// ---------------------------------------------------------------------------
// Ballot instance (601) datum — slim; full results live on IPFS
// Status: 0=created, 1=active, 2=tallying, 3=finalized, 4=contested
// ---------------------------------------------------------------------------

type BallotResult {
    BallotId: Bytes,
    Status: Int,
    ResultsHash: Bytes,
    EvidenceCid: Bytes,
    TotalVoters: Int,
    MerkleRoot: Bytes,
}

// ---------------------------------------------------------------------------
// Register a new voter — mint token with empty datum
// ---------------------------------------------------------------------------

tx register_voter(
    user_id: Bytes,
) {
    input gas {
        from: Voting_Authority,
        min_amount: fees + min_utxo(voter_token),
    }

    mint {
        amount: AnyAsset(token_policy, user_id, 1),
    }

    output voter_token {
        to: Voting_Authority,
        amount: min_utxo(voter_token) + AnyAsset(token_policy, user_id, 1),
        datum: Vote {
            VoterId: user_id,
            Version: 0,
            MerkleRoot: 0x00,
            VoteHash: 0x00,
            IpfsCid: 0x00,
        },
    }

    output {
        to: Voting_Authority,
        amount: gas - fees - min_utxo(voter_token),
    }

    cardano::native_witness {
        script: minting_script,
    }
}

// ---------------------------------------------------------------------------
// Register + vote in one transaction
// ---------------------------------------------------------------------------

tx vote_and_register(
    user_id: Bytes,
    merkle_root: Bytes,
    vote_hash: Bytes,
    ipfs_cid: Bytes,
) {
    input* gas {
        from: Voting_Authority,
        min_amount: fees + Ada(1),
    }

    mint {
        amount: AnyAsset(token_policy, user_id, 1),
    }

    output {
        to: Voting_Authority,
        amount: AnyAsset(token_policy, user_id, 1),
        datum: Vote {
            VoterId: user_id,
            Version: 1,
            MerkleRoot: merkle_root,
            VoteHash: vote_hash,
            IpfsCid: ipfs_cid,
        },
    }

    output {
        to: Voting_Authority,
        amount: gas,
    }

    cardano::native_witness {
        script: minting_script,
    }
}

// ---------------------------------------------------------------------------
// Cast or update a vote on an existing voter token
// ---------------------------------------------------------------------------

tx cast_vote(
    user_id: Bytes,
    version: Int,
    merkle_root: Bytes,
    vote_hash: Bytes,
    ipfs_cid: Bytes,
) {
    input* gas {
        from: Voting_Authority,
        min_amount: Ada(5) + fees + AnyAsset(token_policy, user_id, 1) + min_utxo(voter_token),
    }

    output voter_token {
        to: Voting_Authority,
        amount: min_utxo(voter_token) + AnyAsset(token_policy, user_id, 1),
        datum: Vote {
            VoterId: user_id,
            Version: version,
            MerkleRoot: merkle_root,
            VoteHash: vote_hash,
            IpfsCid: ipfs_cid,
        },
    }

    output {
        to: Voting_Authority,
        amount: gas - fees - min_utxo(voter_token),
    }
}

// ---------------------------------------------------------------------------
// Count/burn a voter token at end of voting
// ---------------------------------------------------------------------------

tx count_vote(
    user_id: Bytes,
) {
    input* gas {
        from: Voting_Authority,
        min_amount: AnyAsset(token_policy, user_id, 1),
    }

    burn {
        amount: AnyAsset(token_policy, user_id, 1),
    }

    cardano::native_witness {
        script: minting_script,
    }
}

// ---------------------------------------------------------------------------
// Finalize ballot — spend (601) instance UTxO, recreate with results datum
// ---------------------------------------------------------------------------

tx finalize_ballot(
    ballot_name: Bytes,
    ballot_id: Bytes,
    results_hash: Bytes,
    evidence_cid: Bytes,
    total_voters: Int,
    merkle_root: Bytes,
) {
    input* gas {
        from: Voting_Authority,
        min_amount: AnyAsset(token_policy, ballot_name, 1) + fees + min_utxo(ballot_result),
    }

    output ballot_result {
        to: Voting_Authority,
        amount: min_utxo(ballot_result) + AnyAsset(token_policy, ballot_name, 1),
        datum: BallotResult {
            BallotId: ballot_id,
            Status: 3,
            ResultsHash: results_hash,
            EvidenceCid: evidence_cid,
            TotalVoters: total_voters,
            MerkleRoot: merkle_root,
        },
    }

    output {
        to: Voting_Authority,
        amount: gas - fees - min_utxo(ballot_result),
    }
}
