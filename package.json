{
  "name": "@lerna-labs/hydra-middleware",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test:unit": "vitest run tests/ --exclude '**/e2e.test.ts' --exclude '**/load.test.ts'",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "test:load": "vitest run tests/load.test.ts"
  },
  "dependencies": {
    "@emurgo/cardano-message-signing-nodejs": "^1.1.0",
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
    "@lerna-labs/ekklesia-helpers": "^1.1.0",
    "@lerna-labs/hydra-proof": "^1.0.0-beta.1",
    "@lerna-labs/hydra-sdk": "^2.0.0-beta.1",
    "@meshsdk/core": "^1.9.0-beta.83",
    "bech32": "^2.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "tx3-sdk": "^0.7.0"
  },
  "overrides": {
    "libsodium-sumo": "0.7.15"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
