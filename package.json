{
  "name": "@lerna-labs/hydra-middleware",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@lerna-labs/hydra-sdk": "^1.0.0-beta.9",
    "@meshsdk/core": "^1.9.0-beta.83",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "tx3-sdk": "^0.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
